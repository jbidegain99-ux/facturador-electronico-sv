# Database - Azure SQL Server
DATABASE_URL=sqlserver://facturador-rc-sql.database.windows.net:1433;database=facturadordb;user=sqladmin;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=false

# API
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Ministerio de Hacienda
MH_API_BASE_URL=https://apitest.dtes.mh.gob.sv
MH_API_ENV=test
MH_AMBIENTE=00
MH_NIT=
MH_NRC=
MH_PASSWORD_PRIVADO=

# Certificado de firma
# CERT_PATH — Path to the digital signing certificate file (.p12/.pfx)
CERT_PATH=./certs/certificado.p12
# CERT_PASSWORD — Password for the digital signing certificate (.p12/.pfx)
CERT_PASSWORD=

# CORS_ORIGINS — Comma-separated list of allowed CORS origins (alternative to CORS_ORIGIN)
CORS_ORIGINS=

# DEMO_MODE — Enable demo mode (true/false), disables real MH transmission
DEMO_MODE=false

# WELLNEST_WEBHOOK_SECRET — Webhook signing secret for Wellnest integration
WELLNEST_WEBHOOK_SECRET=
