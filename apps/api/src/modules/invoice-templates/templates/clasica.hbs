<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link href="https://fonts.googleapis.com/css2?family={{config.fonts.heading}}:wght@400;600;700&family={{config.fonts.body}}:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-primary: {{config.colors.primary}};
      --color-secondary: {{config.colors.secondary}};
      --color-accent: {{config.colors.accent}};
      --color-bg: {{config.colors.background}};
      --color-text: {{config.colors.text}};
      --color-text-light: {{config.colors.textLight}};
      --font-heading: '{{config.fonts.heading}}', sans-serif;
      --font-body: '{{config.fonts.body}}', sans-serif;
    }

    @page {
      size: {{config.pageSettings.size}};
      margin: {{config.pageSettings.margins.top}}mm {{config.pageSettings.margins.right}}mm {{config.pageSettings.margins.bottom}}mm {{config.pageSettings.margins.left}}mm;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      font-size: 10px;
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.4;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 15px;
      padding-bottom: 10px;
      border-bottom: 3px solid var(--color-primary);
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
    }

    .logo img {
      max-width: {{config.logo.maxWidth}}px;
      max-height: {{config.logo.maxHeight}}px;
      object-fit: contain;
    }

    .header-right {
      text-align: right;
      min-width: 220px;
    }

    .dte-type {
      font-family: var(--font-heading);
      font-size: 13px;
      font-weight: 700;
      color: var(--color-primary);
      margin-bottom: 4px;
    }

    .dte-info {
      font-size: 9px;
      color: var(--color-text-light);
      line-height: 1.6;
    }

    .dte-info strong { color: var(--color-text); }

    .estado {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 8px;
      font-weight: 600;
      text-transform: uppercase;
      margin-top: 4px;
    }

    .estado-procesado { background: #DEF7EC; color: #03543F; }
    .estado-rechazado { background: #FDE8E8; color: #9B1C1C; }
    .estado-anulado { background: #FDE8E8; color: #9B1C1C; }
    .estado-default { background: #E1EFFE; color: #1E429F; }

    .section { margin-bottom: 12px; }

    .section-title {
      font-family: var(--font-heading);
      font-size: 10px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
      padding-bottom: 3px;
      border-bottom: 1px solid var(--color-accent);
    }

    .two-cols {
      display: flex;
      gap: 20px;
    }

    .two-cols > div { flex: 1; }

    .info-row {
      display: flex;
      margin-bottom: 2px;
      font-size: 9px;
    }

    .info-label {
      font-weight: 600;
      min-width: 80px;
      color: var(--color-text-light);
    }

    .info-value { color: var(--color-text); }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 12px;
      font-size: 9px;
    }

    .items-table thead th {
      background: var(--color-primary);
      color: #fff;
      padding: 6px 8px;
      text-align: left;
      font-weight: 600;
      font-family: var(--font-heading);
      font-size: 8px;
      text-transform: uppercase;
    }

    .items-table thead th:first-child { border-radius: 4px 0 0 0; }
    .items-table thead th:last-child { border-radius: 0 4px 0 0; }

    .items-table tbody td {
      padding: 5px 8px;
      border-bottom: 1px solid #E5E7EB;
    }

    .items-table tbody tr:nth-child(even) {
      background: #F9FAFB;
    }

    .text-right { text-align: right; }
    .text-center { text-align: center; }

    .totals-section {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 12px;
    }

    .totals-table {
      width: 280px;
      border-collapse: collapse;
      font-size: 9px;
    }

    .totals-table td {
      padding: 4px 8px;
    }

    .totals-table .label {
      text-align: right;
      color: var(--color-text-light);
      font-weight: 500;
    }

    .totals-table .value {
      text-align: right;
      font-weight: 600;
      min-width: 90px;
    }

    .totals-table .total-row td {
      border-top: 2px solid var(--color-primary);
      font-size: 12px;
      font-weight: 700;
      color: var(--color-primary);
      padding-top: 6px;
    }

    .total-letras {
      font-size: 8px;
      font-style: italic;
      color: var(--color-text-light);
      margin-bottom: 12px;
      text-align: right;
    }

    .footer-section {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-top: 15px;
      padding-top: 10px;
      border-top: 1px solid #E5E7EB;
    }

    .qr-section {
      text-align: center;
    }

    .qr-section img {
      width: 100px;
      height: 100px;
    }

    .qr-label {
      font-size: 7px;
      color: var(--color-text-light);
      margin-top: 3px;
    }

    .sello-section {
      font-size: 8px;
      color: var(--color-text-light);
      text-align: right;
      max-width: 350px;
    }

    .sello-section strong {
      color: var(--color-text);
    }

    .doc-footer {
      text-align: center;
      font-size: 7px;
      color: var(--color-text-light);
      margin-top: 10px;
      padding-top: 5px;
      border-top: 1px dashed #D1D5DB;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(-45deg);
      font-size: 80px;
      font-weight: 700;
      color: rgba(239, 68, 68, 0.08);
      pointer-events: none;
      z-index: 1000;
      white-space: nowrap;
    }

    .observaciones {
      font-size: 8px;
      color: var(--color-text-light);
      padding: 6px 8px;
      background: #F9FAFB;
      border-radius: 4px;
      margin-bottom: 12px;
    }
  </style>
</head>
<body>
  {{#if isDemoMode}}<div class="watermark">MODO DEMO</div>{{/if}}

  {{!-- HEADER --}}
  {{#if config.sections.header.visible}}
  <div class="header">
    <div class="header-left">
      {{#if logoDataUrl}}
      <div class="logo" style="text-align: {{config.logo.position}};">
        <img src="{{logoDataUrl}}" alt="Logo">
      </div>
      {{/if}}
      {{#if config.sections.emisor.visible}}
      <div class="emisor-info">
        <div style="font-family: var(--font-heading); font-size: 14px; font-weight: 700; color: var(--color-primary);">{{emisor.nombre}}</div>
        {{#if emisor.nit}}<div class="dte-info">NIT: {{emisor.nit}}</div>{{/if}}
        {{#if emisor.nrc}}<div class="dte-info">NRC: {{emisor.nrc}}</div>{{/if}}
        {{#if emisor.direccionFormateada}}<div class="dte-info">{{emisor.direccionFormateada}}</div>{{/if}}
        {{#if emisor.telefono}}<div class="dte-info">Tel: {{emisor.telefono}}</div>{{/if}}
        {{#if emisor.correo}}<div class="dte-info">{{emisor.correo}}</div>{{/if}}
      </div>
      {{/if}}
    </div>
    <div class="header-right">
      <div class="dte-type">{{dteTypeName tipoDte}}</div>
      <div class="dte-info">
        <div><strong>N° Control:</strong> {{numeroControl}}</div>
        <div><strong>Código Gen.:</strong> {{codigoGeneracion}}</div>
        {{#if identificacion.fecEmi}}<div><strong>Fecha:</strong> {{formatDate identificacion.fecEmi}}</div>{{/if}}
        {{#if identificacion.horEmi}}<div><strong>Hora:</strong> {{formatTime identificacion.horEmi}}</div>{{/if}}
      </div>
      <span class="estado {{#if (eq estado 'PROCESADO')}}estado-procesado{{else}}{{#if (or (eq estado 'RECHAZADO') (eq estado 'ANULADO'))}}estado-rechazado{{else}}estado-default{{/if}}{{/if}}">
        {{estado}}
      </span>
    </div>
  </div>
  {{/if}}

  {{!-- RECEPTOR --}}
  {{#if config.sections.receptor.visible}}
  <div class="section">
    <div class="section-title">Datos del Receptor</div>
    <div class="two-cols">
      <div>
        {{#if receptor.nombre}}<div class="info-row"><span class="info-label">Nombre:</span><span class="info-value">{{receptor.nombre}}</span></div>{{/if}}
        {{#if receptor.numDocumento}}<div class="info-row"><span class="info-label">Documento:</span><span class="info-value">{{receptor.numDocumento}}</span></div>{{/if}}
        {{#if receptor.nit}}<div class="info-row"><span class="info-label">NIT:</span><span class="info-value">{{receptor.nit}}</span></div>{{/if}}
        {{#if receptor.nrc}}<div class="info-row"><span class="info-label">NRC:</span><span class="info-value">{{receptor.nrc}}</span></div>{{/if}}
      </div>
      <div>
        {{#if receptor.direccionFormateada}}<div class="info-row"><span class="info-label">Dirección:</span><span class="info-value">{{receptor.direccionFormateada}}</span></div>{{/if}}
        {{#if receptor.telefono}}<div class="info-row"><span class="info-label">Teléfono:</span><span class="info-value">{{receptor.telefono}}</span></div>{{/if}}
        {{#if receptor.correo}}<div class="info-row"><span class="info-label">Correo:</span><span class="info-value">{{receptor.correo}}</span></div>{{/if}}
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- ITEMS --}}
  {{#if config.sections.items.visible}}
  <div class="section">
    <table class="items-table">
      <thead>
        <tr>
          <th style="width: 30px;">#</th>
          <th style="width: 50px;">Cant.</th>
          <th>Descripción</th>
          <th class="text-right" style="width: 80px;">P. Unit.</th>
          {{#if (or (eq tipoDte "01") (eq tipoDte "11") (eq tipoDte "14"))}}
          <th class="text-right" style="width: 80px;">Gravada</th>
          {{/if}}
          {{#if (eq tipoDte "03")}}
          <th class="text-right" style="width: 80px;">Gravada</th>
          <th class="text-right" style="width: 70px;">IVA</th>
          {{/if}}
          {{#if (or (eq tipoDte "05") (eq tipoDte "06"))}}
          <th class="text-right" style="width: 80px;">Monto</th>
          {{/if}}
          {{#unless (or (eq tipoDte "01") (eq tipoDte "03") (eq tipoDte "05") (eq tipoDte "06") (eq tipoDte "11") (eq tipoDte "14"))}}
          <th class="text-right" style="width: 80px;">Subtotal</th>
          {{/unless}}
        </tr>
      </thead>
      <tbody>
        {{#each cuerpoDocumento}}
        <tr>
          <td class="text-center">{{this.numItem}}</td>
          <td class="text-center">{{this.cantidad}}</td>
          <td>{{this.descripcion}}</td>
          <td class="text-right">{{formatCurrency this.precioUni}}</td>
          {{#if (or (eq ../tipoDte "01") (eq ../tipoDte "11") (eq ../tipoDte "14"))}}
          <td class="text-right">{{formatCurrency this.ventaGravada}}</td>
          {{/if}}
          {{#if (eq ../tipoDte "03")}}
          <td class="text-right">{{formatCurrency this.ventaGravada}}</td>
          <td class="text-right">{{formatCurrency this.ivaItem}}</td>
          {{/if}}
          {{#if (or (eq ../tipoDte "05") (eq ../tipoDte "06"))}}
          <td class="text-right">{{formatCurrency (or this.ventaGravada this.montoDescu this.ventaExenta)}}</td>
          {{/if}}
          {{#unless (or (eq ../tipoDte "01") (eq ../tipoDte "03") (eq ../tipoDte "05") (eq ../tipoDte "06") (eq ../tipoDte "11") (eq ../tipoDte "14"))}}
          <td class="text-right">{{formatCurrency (or this.ventaGravada this.compra this.ventaExenta)}}</td>
          {{/unless}}
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- RESUMEN --}}
  {{#if config.sections.resumen.visible}}
  <div class="totals-section">
    <table class="totals-table">
      {{#if (gt resumen.totalGravada 0)}}
      <tr><td class="label">Subtotal Gravado:</td><td class="value">{{formatCurrency resumen.totalGravada}}</td></tr>
      {{/if}}
      {{#if (gt resumen.totalExenta 0)}}
      <tr><td class="label">Subtotal Exento:</td><td class="value">{{formatCurrency resumen.totalExenta}}</td></tr>
      {{/if}}
      {{#if (gt resumen.totalNoSuj 0)}}
      <tr><td class="label">Subtotal No Sujeto:</td><td class="value">{{formatCurrency resumen.totalNoSuj}}</td></tr>
      {{/if}}
      {{#if (gt resumen.subTotal 0)}}
      <tr><td class="label">Subtotal:</td><td class="value">{{formatCurrency resumen.subTotal}}</td></tr>
      {{/if}}
      {{!-- IVA for Factura (tipo 01) - included in price --}}
      {{#if (eq tipoDte "01")}}
      {{#if totalIva}}
      <tr><td class="label">IVA (incluido):</td><td class="value">{{formatCurrency totalIva}}</td></tr>
      {{/if}}
      {{/if}}
      {{!-- IVA for CCF (tipo 03) - added separately --}}
      {{#if (eq tipoDte "03")}}
      {{#if totalIva}}
      <tr><td class="label">IVA 13%:</td><td class="value">{{formatCurrency totalIva}}</td></tr>
      {{/if}}
      {{/if}}
      {{#if (gt resumen.ivaRetenido 0)}}
      <tr><td class="label">IVA Retenido:</td><td class="value">{{formatCurrency resumen.ivaRetenido}}</td></tr>
      {{/if}}
      {{#if (gt resumen.reteRenta 0)}}
      <tr><td class="label">Retención Renta:</td><td class="value">{{formatCurrency resumen.reteRenta}}</td></tr>
      {{/if}}
      <tr class="total-row">
        <td class="label">TOTAL:</td>
        <td class="value">{{formatCurrency resumen.totalPagar}}</td>
      </tr>
    </table>
  </div>

  {{#if resumen.totalLetras}}
  <div class="total-letras">
    Son: {{resumen.totalLetras}}
  </div>
  {{else}}
  {{#if resumen.totalPagar}}
  <div class="total-letras">
    Son: {{totalLetras resumen.totalPagar}}
  </div>
  {{/if}}
  {{/if}}
  {{/if}}

  {{!-- OBSERVACIONES --}}
  {{#if config.sections.observaciones.visible}}
  {{#if identificacion.observaciones}}
  <div class="observaciones">
    <strong>Observaciones:</strong> {{identificacion.observaciones}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- FOOTER: QR + SELLO --}}
  <div class="footer-section">
    {{#if config.sections.qrCode.visible}}
    {{#if qrDataUrl}}
    <div class="qr-section">
      <img src="{{qrDataUrl}}" alt="QR">
      <div class="qr-label">Consulta pública - Ministerio de Hacienda</div>
    </div>
    {{/if}}
    {{/if}}

    {{#if config.sections.selloRecepcion.visible}}
    {{#if selloRecibido}}
    <div class="sello-section">
      <div><strong>Sello de Recepción:</strong></div>
      <div style="word-break: break-all;">{{selloRecibido}}</div>
      {{#if fhProcesamiento}}
      <div style="margin-top: 4px;"><strong>Fecha Procesamiento:</strong> {{fhProcesamiento}}</div>
      {{/if}}
    </div>
    {{/if}}
    {{/if}}
  </div>

  {{!-- FOOTER LEGAL --}}
  {{#if config.sections.footer.visible}}
  <div class="doc-footer">
    Documento Tributario Electrónico — {{dteTypeName tipoDte}}
    {{#if isDemoMode}}<br>DOCUMENTO DE PRUEBA — SIN VALIDEZ FISCAL{{/if}}
  </div>
  {{/if}}
</body>
</html>
