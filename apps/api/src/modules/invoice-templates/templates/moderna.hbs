<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <link href="https://fonts.googleapis.com/css2?family={{config.fonts.heading}}:wght@400;600;700&family={{config.fonts.body}}:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-primary: {{config.colors.primary}};
      --color-secondary: {{config.colors.secondary}};
      --color-accent: {{config.colors.accent}};
      --color-bg: {{config.colors.background}};
      --color-text: {{config.colors.text}};
      --color-text-light: {{config.colors.textLight}};
      --font-heading: '{{config.fonts.heading}}', sans-serif;
      --font-body: '{{config.fonts.body}}', sans-serif;
    }

    @page {
      size: {{config.pageSettings.size}};
      margin: {{config.pageSettings.margins.top}}mm {{config.pageSettings.margins.right}}mm {{config.pageSettings.margins.bottom}}mm {{config.pageSettings.margins.left}}mm;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-body);
      font-size: 10px;
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.5;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    .header {
      text-align: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
    }

    .logo { margin-bottom: 8px; }

    .logo img {
      max-width: {{config.logo.maxWidth}}px;
      max-height: {{config.logo.maxHeight}}px;
      object-fit: contain;
    }

    .dte-badge {
      display: inline-block;
      background: var(--color-primary);
      color: #fff;
      padding: 4px 16px;
      border-radius: 20px;
      font-family: var(--font-heading);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }

    .dte-meta {
      display: flex;
      justify-content: center;
      gap: 20px;
      font-size: 9px;
      color: var(--color-text-light);
    }

    .dte-meta span { white-space: nowrap; }
    .dte-meta strong { color: var(--color-text); }

    .estado-badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 8px;
      font-weight: 600;
      text-transform: uppercase;
      margin-top: 6px;
    }

    .estado-procesado { background: #DEF7EC; color: #03543F; }
    .estado-rechazado { background: #FDE8E8; color: #9B1C1C; }
    .estado-anulado { background: #FDE8E8; color: #9B1C1C; }
    .estado-default { background: #E1EFFE; color: #1E429F; }

    .cards-row {
      display: flex;
      gap: 15px;
      margin-bottom: 18px;
    }

    .card {
      flex: 1;
      background: #F9FAFB;
      border: 1px solid #E5E7EB;
      border-radius: 8px;
      padding: 12px 14px;
    }

    .card-title {
      font-family: var(--font-heading);
      font-size: 9px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .card-row {
      font-size: 9px;
      margin-bottom: 2px;
      line-height: 1.5;
    }

    .card-row .label {
      color: var(--color-text-light);
      font-weight: 500;
    }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 18px;
      font-size: 9px;
    }

    .items-table thead th {
      padding: 8px 10px;
      text-align: left;
      font-weight: 600;
      font-family: var(--font-heading);
      font-size: 8px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      color: var(--color-text-light);
      border-bottom: 2px solid var(--color-primary);
    }

    .items-table tbody td {
      padding: 7px 10px;
      border-bottom: 1px solid #F3F4F6;
    }

    .items-table tbody tr:hover {
      background: #FAFAFA;
    }

    .text-right { text-align: right; }
    .text-center { text-align: center; }

    .totals-card {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 15px;
    }

    .totals-inner {
      background: linear-gradient(135deg, var(--color-primary)08, var(--color-accent)15);
      border: 1px solid var(--color-accent);
      border-radius: 8px;
      padding: 12px 16px;
      min-width: 260px;
    }

    .totals-row {
      display: flex;
      justify-content: space-between;
      padding: 3px 0;
      font-size: 9px;
    }

    .totals-row .label { color: var(--color-text-light); }
    .totals-row .value { font-weight: 600; }

    .totals-row.total {
      border-top: 2px solid var(--color-primary);
      margin-top: 6px;
      padding-top: 8px;
      font-size: 14px;
      font-weight: 700;
      color: var(--color-primary);
      font-family: var(--font-heading);
    }

    .total-letras {
      font-size: 8px;
      font-style: italic;
      color: var(--color-text-light);
      text-align: right;
      margin-bottom: 15px;
    }

    .qr-footer {
      text-align: center;
      margin-top: 15px;
      padding-top: 12px;
      border-top: 1px solid #E5E7EB;
    }

    .qr-footer img {
      width: 110px;
      height: 110px;
    }

    .qr-label {
      font-size: 7px;
      color: var(--color-text-light);
      margin-top: 4px;
    }

    .sello-info {
      font-size: 8px;
      color: var(--color-text-light);
      text-align: center;
      margin-top: 8px;
      word-break: break-all;
    }

    .sello-info strong { color: var(--color-text); }

    .doc-footer {
      text-align: center;
      font-size: 7px;
      color: var(--color-text-light);
      margin-top: 12px;
      padding-top: 8px;
      border-top: 1px dashed #D1D5DB;
    }

    .watermark {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(-45deg);
      font-size: 80px;
      font-weight: 700;
      color: rgba(239, 68, 68, 0.08);
      pointer-events: none;
      z-index: 1000;
      white-space: nowrap;
    }

    .observaciones {
      font-size: 8px;
      color: var(--color-text-light);
      padding: 8px 12px;
      background: #F9FAFB;
      border-radius: 6px;
      border-left: 3px solid var(--color-accent);
      margin-bottom: 15px;
    }
  </style>
</head>
<body>
  {{#if isDemoMode}}<div class="watermark">MODO DEMO</div>{{/if}}

  {{!-- HEADER --}}
  {{#if config.sections.header.visible}}
  <div class="header">
    {{#if logoDataUrl}}
    <div class="logo">
      <img src="{{logoDataUrl}}" alt="Logo">
    </div>
    {{/if}}
    <div class="dte-badge">{{dteTypeName tipoDte}}</div>
    <div class="dte-meta">
      <span><strong>N° Control:</strong> {{numeroControl}}</span>
      <span><strong>Código Gen.:</strong> {{codigoGeneracion}}</span>
      {{#if identificacion.fecEmi}}<span><strong>Fecha:</strong> {{formatDate identificacion.fecEmi}}</span>{{/if}}
      {{#if identificacion.horEmi}}<span><strong>Hora:</strong> {{formatTime identificacion.horEmi}}</span>{{/if}}
    </div>
    <span class="estado-badge {{#if (eq estado 'PROCESADO')}}estado-procesado{{else}}{{#if (or (eq estado 'RECHAZADO') (eq estado 'ANULADO'))}}estado-rechazado{{else}}estado-default{{/if}}{{/if}}">
      {{estado}}
    </span>
  </div>
  {{/if}}

  {{!-- EMISOR + RECEPTOR CARDS --}}
  <div class="cards-row">
    {{#if config.sections.emisor.visible}}
    <div class="card">
      <div class="card-title">Emisor</div>
      <div class="card-row" style="font-weight: 600; font-size: 10px; margin-bottom: 4px;">{{emisor.nombre}}</div>
      {{#if emisor.nit}}<div class="card-row"><span class="label">NIT:</span> {{emisor.nit}}</div>{{/if}}
      {{#if emisor.nrc}}<div class="card-row"><span class="label">NRC:</span> {{emisor.nrc}}</div>{{/if}}
      {{#if emisor.direccionFormateada}}<div class="card-row">{{emisor.direccionFormateada}}</div>{{/if}}
      {{#if emisor.telefono}}<div class="card-row">Tel: {{emisor.telefono}}</div>{{/if}}
      {{#if emisor.correo}}<div class="card-row">{{emisor.correo}}</div>{{/if}}
    </div>
    {{/if}}

    {{#if config.sections.receptor.visible}}
    <div class="card">
      <div class="card-title">Receptor</div>
      {{#if receptor.nombre}}<div class="card-row" style="font-weight: 600; font-size: 10px; margin-bottom: 4px;">{{receptor.nombre}}</div>{{/if}}
      {{#if receptor.nit}}<div class="card-row"><span class="label">NIT:</span> {{receptor.nit}}</div>{{/if}}
      {{#if receptor.nrc}}<div class="card-row"><span class="label">NRC:</span> {{receptor.nrc}}</div>{{/if}}
      {{#if receptor.numDocumento}}<div class="card-row"><span class="label">Doc:</span> {{receptor.numDocumento}}</div>{{/if}}
      {{#if receptor.direccionFormateada}}<div class="card-row">{{receptor.direccionFormateada}}</div>{{/if}}
      {{#if receptor.telefono}}<div class="card-row">Tel: {{receptor.telefono}}</div>{{/if}}
      {{#if receptor.correo}}<div class="card-row">{{receptor.correo}}</div>{{/if}}
    </div>
    {{/if}}
  </div>

  {{!-- ITEMS TABLE --}}
  {{#if config.sections.items.visible}}
  <table class="items-table">
    <thead>
      <tr>
        <th style="width: 30px;">#</th>
        <th style="width: 45px;">Cant.</th>
        <th>Descripción</th>
        <th class="text-right" style="width: 75px;">P. Unit.</th>
        {{#if (or (eq tipoDte "01") (eq tipoDte "11") (eq tipoDte "14"))}}
        <th class="text-right" style="width: 75px;">Gravada</th>
        {{/if}}
        {{#if (eq tipoDte "03")}}
        <th class="text-right" style="width: 75px;">Gravada</th>
        <th class="text-right" style="width: 65px;">IVA</th>
        {{/if}}
        {{#if (or (eq tipoDte "05") (eq tipoDte "06"))}}
        <th class="text-right" style="width: 75px;">Monto</th>
        {{/if}}
        {{#unless (or (eq tipoDte "01") (eq tipoDte "03") (eq tipoDte "05") (eq tipoDte "06") (eq tipoDte "11") (eq tipoDte "14"))}}
        <th class="text-right" style="width: 75px;">Subtotal</th>
        {{/unless}}
      </tr>
    </thead>
    <tbody>
      {{#each cuerpoDocumento}}
      <tr>
        <td class="text-center">{{this.numItem}}</td>
        <td class="text-center">{{this.cantidad}}</td>
        <td>{{this.descripcion}}</td>
        <td class="text-right">{{formatCurrency this.precioUni}}</td>
        {{#if (or (eq ../tipoDte "01") (eq ../tipoDte "11") (eq ../tipoDte "14"))}}
        <td class="text-right">{{formatCurrency this.ventaGravada}}</td>
        {{/if}}
        {{#if (eq ../tipoDte "03")}}
        <td class="text-right">{{formatCurrency this.ventaGravada}}</td>
        <td class="text-right">{{formatCurrency this.ivaItem}}</td>
        {{/if}}
        {{#if (or (eq ../tipoDte "05") (eq ../tipoDte "06"))}}
        <td class="text-right">{{formatCurrency (or this.ventaGravada this.montoDescu this.ventaExenta)}}</td>
        {{/if}}
        {{#unless (or (eq ../tipoDte "01") (eq ../tipoDte "03") (eq ../tipoDte "05") (eq ../tipoDte "06") (eq ../tipoDte "11") (eq ../tipoDte "14"))}}
        <td class="text-right">{{formatCurrency (or this.ventaGravada this.compra this.ventaExenta)}}</td>
        {{/unless}}
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  {{!-- TOTALS --}}
  {{#if config.sections.resumen.visible}}
  <div class="totals-card">
    <div class="totals-inner">
      {{#if (gt resumen.totalGravada 0)}}
      <div class="totals-row"><span class="label">Subtotal Gravado</span><span class="value">{{formatCurrency resumen.totalGravada}}</span></div>
      {{/if}}
      {{#if (gt resumen.totalExenta 0)}}
      <div class="totals-row"><span class="label">Subtotal Exento</span><span class="value">{{formatCurrency resumen.totalExenta}}</span></div>
      {{/if}}
      {{#if (gt resumen.totalNoSuj 0)}}
      <div class="totals-row"><span class="label">Subtotal No Sujeto</span><span class="value">{{formatCurrency resumen.totalNoSuj}}</span></div>
      {{/if}}
      {{#if (eq tipoDte "01")}}
      {{#if totalIva}}
      <div class="totals-row"><span class="label">IVA (incluido)</span><span class="value">{{formatCurrency totalIva}}</span></div>
      {{/if}}
      {{/if}}
      {{#if (eq tipoDte "03")}}
      {{#if totalIva}}
      <div class="totals-row"><span class="label">IVA 13%</span><span class="value">{{formatCurrency totalIva}}</span></div>
      {{/if}}
      {{/if}}
      {{#if (gt resumen.ivaRetenido 0)}}
      <div class="totals-row"><span class="label">IVA Retenido</span><span class="value">{{formatCurrency resumen.ivaRetenido}}</span></div>
      {{/if}}
      {{#if (gt resumen.reteRenta 0)}}
      <div class="totals-row"><span class="label">Retención Renta</span><span class="value">{{formatCurrency resumen.reteRenta}}</span></div>
      {{/if}}
      <div class="totals-row total"><span>TOTAL</span><span>{{formatCurrency resumen.totalPagar}}</span></div>
    </div>
  </div>

  {{#if resumen.totalLetras}}
  <div class="total-letras">Son: {{resumen.totalLetras}}</div>
  {{else}}
  {{#if resumen.totalPagar}}
  <div class="total-letras">Son: {{totalLetras resumen.totalPagar}}</div>
  {{/if}}
  {{/if}}
  {{/if}}

  {{!-- OBSERVACIONES --}}
  {{#if config.sections.observaciones.visible}}
  {{#if identificacion.observaciones}}
  <div class="observaciones">
    <strong>Observaciones:</strong> {{identificacion.observaciones}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- QR + SELLO --}}
  {{#if config.sections.qrCode.visible}}
  {{#if qrDataUrl}}
  <div class="qr-footer">
    <img src="{{qrDataUrl}}" alt="QR">
    <div class="qr-label">Consulta pública — Ministerio de Hacienda</div>
  </div>
  {{/if}}
  {{/if}}

  {{#if config.sections.selloRecepcion.visible}}
  {{#if selloRecibido}}
  <div class="sello-info">
    <strong>Sello de Recepción:</strong> {{selloRecibido}}
    {{#if fhProcesamiento}}<br><strong>Procesado:</strong> {{fhProcesamiento}}{{/if}}
  </div>
  {{/if}}
  {{/if}}

  {{!-- FOOTER --}}
  {{#if config.sections.footer.visible}}
  <div class="doc-footer">
    Documento Tributario Electrónico — {{dteTypeName tipoDte}}
    {{#if isDemoMode}}<br>DOCUMENTO DE PRUEBA — SIN VALIDEZ FISCAL{{/if}}
  </div>
  {{/if}}
</body>
</html>
